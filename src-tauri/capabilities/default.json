{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-login",
    "allow-read-project-file",
    "allow-list-art-skills",
    "allow-list-story-skills",
    "allow-get-art-skill-detail",
    "allow-get-story-skill-detail",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*" },
        { "url": "http://*:*" },
        { "url": "https://aiplatform.njsrd.com/**" },
        { "url": "https://*.njsrd.com/**" }
      ]
    }
  ]
}
