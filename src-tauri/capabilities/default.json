{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-login",
    "allow-create-project",
    "allow-list-projects",
    "allow-update-project",
    "allow-delete-project",
    "allow-assistant-context",
    "allow-list-art-skills",
    "allow-list-story-skills",
    "allow-get-art-skill-detail",
    "allow-get-story-skill-detail",
    "allow-list-director-manuals",
    "allow-get-director-manual",
    "allow-novel",
    "allow-workflow",
    "allow-assets",
    "allow-script",
    "allow-db-admin",
    "allow-llm",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*" },
        { "url": "http://*:*" },
        { "url": "https://aiplatform.njsrd.com/**" },
        { "url": "https://*.njsrd.com/**" }
      ]
    }
  ]
}
